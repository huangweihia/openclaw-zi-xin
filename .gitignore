.env
.env.*.local
.env.local

/vendor/
/node_modules/

# Laravel caches / runtime
/bootstrap/cache/*.php
/storage/*.key
/public/storage
/storage/app/public/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*

